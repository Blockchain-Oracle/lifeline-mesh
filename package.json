{
  "name": "lifeline-mesh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.17.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.base.json && pnpm -r --if-present typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:sloc": "node scripts/check-sloc.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "schema:check": "node scripts/check-schemas.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "require-asset": "^1.2.2"
  }
}

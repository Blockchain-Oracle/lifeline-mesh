node_modules/
dist/
*.tsbuildinfo
.DS_Store
*.log

# Model weights and large binaries — never commit; fetched by setup scripts
*.gguf
*.bin
kb/source/*.pdf

# Derivable intermediate: page-marked text extracted from the PDF by ingest.mjs
kb/source/.text/

# Built RAG DB can be large; commit only if under limits (tracked via LFS otherwise)
# kb/workspace.sqlite

# Local env + secrets
.env
.env.*
infra/pi/*.env

# Raw audit NDJSON is regenerated per run; keep the aggregated submission JSON only
submission/*.ndjson

# Copy to infra/pi/lifeline.env (gitignored) and fill in. Read by the systemd unit.

# Log level for the junior node.
LOG_LEVEL=info

# TTS backend: supertonic (default) or espeak (fallback if Supertonic won't load on ARM).
TTS_BACKEND=supertonic

# OPTIONAL — the senior laptop's provider public key, to enable P2P escalation.
# Get it by running `pnpm --filter @lifeline/senior-node start` on the laptop.
# LIFELINE_SENIOR_KEY=<64-or-more-char-hex-public-key>

# OPTIONAL — deterministic Hyperswarm identity for this node (64-hex). Only needed
# if this node also acts as a provider. Leave unset on a pure consumer (junior).
# QVAC_HYPERSWARM_SEED=

# The QVAC SDK runs on Holepunch's Bare runtime, which loads native binaries via
# chained dynamic require()s (bare-runtime -> bare-runtime-<platform>-<arch> ->
# require-asset -> ...). pnpm's strict nesting hides those from each other, so we
# flatten the tree to an npm-style layout. shamefully-hoist puts every (incl.
# transitive) dependency at the root node_modules so Bare's dynamic requires
# resolve. Verified on darwin-arm64 (2026-06-13).
node-linker=hoisted
shamefully-hoist=true
